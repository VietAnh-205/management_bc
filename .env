# Database (kết nối bằng service name `db` trong docker-compose)

DB_URL=jdbc:mysql://db:3306/circlek_db?allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=123456

# JWT Config
JWT_EXPIRATION=1800
JWT_REFRESH_EXPIRATION=3000

# RSA Key (container sẽ đọc từ classpath: resources/keys)
PUBLIC_KEY_FILE=src/main/resources/keys/public.pem
PRIVATE_KEY_FILE=src/main/resources/keys/private.pem

# JWT Secret (nên đổi sang env bảo mật khi deploy)
JWT_SECRET=jkNF544fDFfdvvdgvDvd5Vd15svd5fvg14vg14d5SDDBVFdbvd5bv1gvvg51dgVDVDv1d5vdvsvBNFNLKHSoledadSmileOpera2TheStar

# Swagger
SWAGGER_ENABLED=true
